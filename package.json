{
	"name": "gutenx-blocks",
	"version": "1.0.0",
	"description": "GutenX Blocks — Production-ready WordPress Gutenberg block library.",
	"author": "GutenX",
	"license": "GPL-2.0-or-later",
	"main": "build/index.js",
	"scripts": {
		"start": "wp-scripts start --webpack-src-dir=src --output-path=build",
		"build": "wp-scripts build --webpack-src-dir=src --output-path=build",
		"lint:js": "wp-scripts lint-js src/**",
		"lint:css": "wp-scripts lint-style src/**",
		"lint:all": "npm run lint:js && npm run lint:css",
		"format": "wp-scripts format src/**",
		"format:check": "wp-scripts format src/** --check",
		"pot": "wp-scripts makepot . languages/gutenx-blocks.pot --slug=gutenx-blocks --domain=gutenx-blocks",
		"check-engines": "wp-scripts check-engines",
		"packages-update": "wp-scripts packages-update",
		"release": "bash bin/build-release.sh"
	},
	"devDependencies": {
		"@wordpress/scripts": "^30.0.0",
		"@wordpress/env": "^10.0.0",
		"css-minimizer-webpack-plugin": "^7.0.0",
		"terser-webpack-plugin": "^5.3.10"
	},
	"dependencies": {
		"@wordpress/api-fetch": "^7.0.0",
		"@wordpress/data": "^10.0.0",
		"@wordpress/components": "^28.0.0",
		"@wordpress/i18n": "^5.0.0",
		"@wordpress/blocks": "^13.0.0",
		"@wordpress/block-editor": "^14.0.0",
		"@wordpress/element": "^6.0.0",
		"@wordpress/icons": "^10.0.0",
		"@wordpress/plugins": "^7.0.0"
	}
}
