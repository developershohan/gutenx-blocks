{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "gutenx-blocks/container",
	"version": "1.0.0",
	"title": "Container",
	"category": "gutenx-blocks",
	"icon": "layout",
	"description": "Versatile wrapper block with Flexbox/Grid layout, background images, and responsive controls.",
	"keywords": [ "container", "wrapper", "section", "layout", "flex", "grid" ],
	"supports": { "html": false, "className": true, "anchor": true },
	"textdomain": "gutenx-blocks",
	"editorScript": "file:../../../build/blocks/container/index.js",
	"style": "file:../../../build/blocks/container/style-index.css",
	"attributes": {
		"tagName": { "type": "string", "default": "div" },
		"displayType": { "type": "string", "default": "flex" },
		"flexDirection": { "type": "string", "default": "row" },
		"flexWrap": { "type": "string", "default": "nowrap" },
		"justifyContent": { "type": "string", "default": "flex-start" },
		"alignItems": { "type": "string", "default": "stretch" },
		"gap": { "type": "string", "default": "16px" },
		"gridColumns": { "type": "number", "default": 3 },
		"minHeight": { "type": "string", "default": "" },
		"maxWidth": { "type": "string", "default": "1200px" },
		"maxWidthTablet": { "type": "string", "default": "" },
		"maxWidthMobile": { "type": "string", "default": "" },
		"isFullWidth": { "type": "boolean", "default": false },
		"backgroundColor": { "type": "string", "default": "#ffffff" },
		"backgroundType": { "type": "string", "default": "color" },
		"backgroundGradient": { "type": "string", "default": "" },
		"backgroundImage": { "type": "object", "default": { "url": "", "id": 0, "alt": "" } },
		"backgroundSize": { "type": "string", "default": "cover" },
		"backgroundPosition": { "type": "string", "default": "center center" },
		"overlayColor": { "type": "string", "default": "#000000" },
		"overlayOpacity": { "type": "number", "default": 0 },
		"borderWidth": { "type": "string", "default": "0px" },
		"borderStyle": { "type": "string", "default": "none" },
		"borderColor": { "type": "string", "default": "#E5E7EB" },
		"borderRadius": { "type": "string", "default": "0px" },
		"borderLinkCorners": { "type": "boolean", "default": true },
		"borderRadiusTopLeft": { "type": "string", "default": "0px" },
		"borderRadiusTopRight": { "type": "string", "default": "0px" },
		"borderRadiusBottomRight": { "type": "string", "default": "0px" },
		"borderRadiusBottomLeft": { "type": "string", "default": "0px" },
		"borderRadiusTopLeftTablet": { "type": "string", "default": "" },
		"borderRadiusTopRightTablet": { "type": "string", "default": "" },
		"borderRadiusBottomRightTablet": { "type": "string", "default": "" },
		"borderRadiusBottomLeftTablet": { "type": "string", "default": "" },
		"borderRadiusTopLeftMobile": { "type": "string", "default": "" },
		"borderRadiusTopRightMobile": { "type": "string", "default": "" },
		"borderRadiusBottomRightMobile": { "type": "string", "default": "" },
		"borderRadiusBottomLeftMobile": { "type": "string", "default": "" },
		"borderRadiusLink": { "type": "boolean", "default": true },
		"marginTop": { "type": "string", "default": "0px" },
		"marginRight": { "type": "string", "default": "0px" },
		"marginBottom": { "type": "string", "default": "0px" },
		"marginLeft": { "type": "string", "default": "0px" },
		"marginTopTablet": { "type": "string", "default": "0px" },
		"marginRightTablet": { "type": "string", "default": "0px" },
		"marginBottomTablet": { "type": "string", "default": "0px" },
		"marginLeftTablet": { "type": "string", "default": "0px" },
		"marginTopMobile": { "type": "string", "default": "0px" },
		"marginRightMobile": { "type": "string", "default": "0px" },
		"marginBottomMobile": { "type": "string", "default": "0px" },
		"marginLeftMobile": { "type": "string", "default": "0px" },
		"paddingTop": { "type": "string", "default": "24px" },
		"paddingRight": { "type": "string", "default": "24px" },
		"paddingBottom": { "type": "string", "default": "24px" },
		"paddingLeft": { "type": "string", "default": "24px" },
		"paddingTopTablet": { "type": "string", "default": "24px" },
		"paddingRightTablet": { "type": "string", "default": "24px" },
		"paddingBottomTablet": { "type": "string", "default": "24px" },
		"paddingLeftTablet": { "type": "string", "default": "24px" },
		"paddingTopMobile": { "type": "string", "default": "24px" },
		"paddingRightMobile": { "type": "string", "default": "24px" },
		"paddingBottomMobile": { "type": "string", "default": "24px" },
		"paddingLeftMobile": { "type": "string", "default": "24px" },
		"spacingDevice": { "type": "string", "default": "desktop" },
		"spacingUnit": { "type": "string", "default": "px" },
		"spacingCustomUnit": { "type": "string", "default": "px" },
		"marginLink": { "type": "boolean", "default": true },
		"paddingLink": { "type": "boolean", "default": true }
	},
	"example": { "attributes": { "displayType": "flex", "maxWidth": "1200px" } }
}
