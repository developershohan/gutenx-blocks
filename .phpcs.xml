<?xml version="1.0"?>
<ruleset name="GutenX Blocks">
	<description>PHP CodeSniffer rules for GutenX Blocks plugin.</description>

	<!-- Scan source files only -->
	<file>./gutenx-blocks.php</file>
	<file>./includes</file>
	<file>./uninstall.php</file>

	<!-- Exclude paths -->
	<exclude-pattern>./node_modules/*</exclude-pattern>
	<exclude-pattern>./vendor/*</exclude-pattern>
	<exclude-pattern>./build/*</exclude-pattern>
	<exclude-pattern>./tests/*</exclude-pattern>

	<!-- Show colors and progress -->
	<arg name="colors"/>
	<arg value="sp"/>

	<!-- Check up to 8 files in parallel -->
	<arg name="parallel" value="8"/>

	<!-- Only check PHP files -->
	<arg name="extensions" value="php"/>

	<!-- WordPress Coding Standards -->
	<rule ref="WordPress">
		<!-- Allow short ternary -->
		<exclude name="WordPress.PHP.DisallowShortTernary"/>
		<!-- Allow short array syntax -->
		<exclude name="Generic.Arrays.DisallowShortArraySyntax"/>
	</rule>

	<!-- WordPress Extra Standards -->
	<rule ref="WordPress-Extra"/>

	<!-- WordPress Documentation Standards -->
	<rule ref="WordPress-Docs"/>

	<!-- Text domain -->
	<rule ref="WordPress.WP.I18n">
		<properties>
			<property name="text_domain" type="array">
				<element value="gutenx-blocks"/>
			</property>
		</properties>
	</rule>

	<!-- Minimum PHP version -->
	<config name="minimum_wp_version" value="6.0"/>
	<config name="testVersion" value="8.0-"/>

	<!-- Prefix checks -->
	<rule ref="WordPress.NamingConventions.PrefixAllGlobals">
		<properties>
			<property name="prefixes" type="array">
				<element value="gutenx"/>
				<element value="GUTENX"/>
				<element value="GutenX_Blocks"/>
			</property>
		</properties>
	</rule>

	<!-- Allow typed properties (PHP 7.4+) -->
	<rule ref="Universal.NamingConventions.NoReservedKeywordParameterNames">
		<exclude-pattern>*</exclude-pattern>
	</rule>
</ruleset>
