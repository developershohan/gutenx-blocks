{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3, "name": "gutenx-blocks/container", "version": "1.0.0", "title": "Container", "category": "gutenx-blocks", "icon": "layout",
	"description": "Versatile wrapper block with Flexbox/Grid layout, background images, and responsive controls.",
	"keywords": [ "container", "wrapper", "section", "layout", "flex", "grid" ],
	"supports": { "html": false, "className": true, "anchor": true },
	"textdomain": "gutenx-blocks",
	"editorScript": "file:../../../build/blocks/container/index.js",
	"style": "file:../../../build/blocks/container/style-index.css",
	"attributes": {
		"tagName": { "type": "string", "default": "div" },
		"displayType": { "type": "string", "default": "block" },
		"flexDirection": { "type": "string", "default": "row" },
		"flexWrap": { "type": "string", "default": "nowrap" },
		"justifyContent": { "type": "string", "default": "flex-start" },
		"alignItems": { "type": "string", "default": "stretch" },
		"gap": { "type": "string", "default": "16px" },
		"gridColumns": { "type": "number", "default": 3 },
		"minHeight": { "type": "string", "default": "" },
		"maxWidth": { "type": "string", "default": "1200px" },
		"isFullWidth": { "type": "boolean", "default": false },
		"backgroundColor": { "type": "string", "default": "#ffffff" },
		"backgroundType": { "type": "string", "default": "color" },
		"backgroundGradient": { "type": "string", "default": "" },
		"backgroundImage": { "type": "object", "default": { "url": "", "id": 0, "alt": "" } },
		"backgroundSize": { "type": "string", "default": "cover" },
		"backgroundPosition": { "type": "string", "default": "center center" },
		"overlayColor": { "type": "string", "default": "#000000" },
		"overlayOpacity": { "type": "number", "default": 0 },
		"borderWidth": { "type": "string", "default": "0px" },
		"borderStyle": { "type": "string", "default": "none" },
		"borderColor": { "type": "string", "default": "#E5E7EB" },
		"borderRadius": { "type": "string", "default": "0px" },
		"borderLinkCorners": { "type": "boolean", "default": true },
		"marginTop": { "type": "string", "default": "0px" },
		"marginRight": { "type": "string", "default": "0px" },
		"marginBottom": { "type": "string", "default": "0px" },
		"marginLeft": { "type": "string", "default": "0px" },
		"paddingTop": { "type": "string", "default": "24px" },
		"paddingRight": { "type": "string", "default": "24px" },
		"paddingBottom": { "type": "string", "default": "24px" },
		"paddingLeft": { "type": "string", "default": "24px" }
	},
	"example": { "attributes": { "displayType": "block", "maxWidth": "1200px" } }
}
